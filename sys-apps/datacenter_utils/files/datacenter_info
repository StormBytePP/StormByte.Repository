#!/bin/bash
# datacenter_info - SCSI disk inventory tool for the datacenter
#
# Displays device identifiers, vendor, model, firmware revision
# and ZFS pool membership for all detected SCSI disks. Handles
# SAS multipath deduplication transparently.
#
# Usage:
#   datacenter_info [-v] [device]
#   datacenter_info help
#
# If device is omitted, all SCSI disks are listed.
#
# The -v flag adds Enclosure/Slot, SMART status, Temperature,
# Link Speed and Health columns (slower — requires smartctl per disk).

set -euo pipefail

VERSION="1.0.0"

source /lib/StormByte/datacenter.sh

show_help() {
    cat <<EOF
datacenter_info v${VERSION} - SCSI disk inventory tool for the datacenter

Display device identifiers, vendor, model, firmware revision and ZFS
pool membership for detected SCSI disks. Handles SAS multipath
deduplication transparently.

Usage:
  datacenter_info [-v] [device]
  datacenter_info help

Options:
  -v          Verbose output: adds Enclosure/Slot, SMART status,
              Temperature, Link Speed and Health columns. Health
              is derived from SMART data: SSD life remaining
              (attr 231), reallocated sector count (attr 5) for
              SATA, or grown defect list for SAS. Requires root
              (smartctl needs raw disk access). May appear before
              or after the device argument.

Device (optional):
  sdX         Block device name (e.g. /dev/sda, sda).
  wwn-*       WWN identifier (e.g. wwn-0x5000cca03e7ce8f8).
  scsi-3*     SCSI NAA identifier (e.g. scsi-35000c500566d10c3).
  ata-*       ATA identifier (e.g. ata-KINGSTON_SA400S37120G_...).

  If omitted, all detected disks are listed.

Examples:
  datacenter_info                   List all SCSI disks.
  datacenter_info -v                List all with extra details.
  datacenter_info sda               Query a specific disk.
  datacenter_info -v sda            Query a specific disk with details.
  datacenter_info help              Display this help message.
EOF
    exit "${1:-0}"
}

# Check for help first
for _arg in "$@"; do
    if [[ "$_arg" == "help" ]]; then
        show_help
    fi
done

# Parse args: -v and/or device in any order
VERBOSE=0
disk=""
for _arg in "$@"; do
    if [[ "$_arg" == "-v" ]]; then
        VERBOSE=1
    else
        disk="$_arg"
    fi
done

if [[ "$VERBOSE" -eq 1 && $EUID -ne 0 ]]; then
    echo "Error: -v requires root (smartctl needs raw disk access)"
    exit 1
fi

POOL_NAME="StormDataCenter"

###############################################################################
# Initialization
###############################################################################

LSSCSI_OUTPUT=$(lsscsi -g 2>/dev/null)
POOL_STATUS=$(zpool status "$POOL_NAME" 2>/dev/null || true)
declare -A SMART_CACHE

init_disk_maps

###############################################################################
# Helper functions
###############################################################################

is_in_pool() {
    local wwn="$1"
    [[ -z "$POOL_STATUS" ]] && return 1
    [[ -v "WWN_ALIASES[$wwn]" ]] || return 1
    local alias
    for alias in ${WWN_ALIASES[$wwn]}; do
        grep -qwF "$alias" <<< "$POOL_STATUS" && return 0
    done
    return 1
}

_ensure_smart_cache() {
    local sd="$1"
    if [[ ! -v "SMART_CACHE[$sd]" ]]; then
        SMART_CACHE[$sd]=$(smartctl -a "/dev/$sd" 2>/dev/null || true)
    fi
}

get_smart_status() {
    local sd="$1"
    _ensure_smart_cache "$sd"
    local output="${SMART_CACHE[$sd]}"
    [[ -z "$output" ]] && { echo "N/A"; return; }
    if grep -qiE 'SMART overall-health.*PASSED|SMART Health Status.*OK' <<< "$output"; then
        echo "PASSED"
    elif grep -qiE 'SMART overall-health.*FAILED|SMART Health Status.*FAIL' <<< "$output"; then
        echo "FAILED"
    elif grep -qi 'SMART' <<< "$output"; then
        echo "WARN"
    else
        echo "N/A"
    fi
}

get_temperature() {
    local sd="$1"
    _ensure_smart_cache "$sd"
    local output="${SMART_CACHE[$sd]}"
    [[ -z "$output" ]] && { echo "N/A"; return; }
    # SAS: "Current Drive Temperature:     35 C"
    local temp
    temp=$(grep -i 'Current Drive Temperature' <<< "$output" | awk '{for(i=1;i<=NF;i++) if($i+0==$i) print $i}' | head -1)
    # SATA: attribute 194
    if [[ -z "$temp" ]]; then
        temp=$(awk '/^194 / {print $10}' <<< "$output" | head -1)
    fi
    if [[ -n "$temp" && "$temp" =~ ^[0-9]+$ ]]; then
        echo "${temp}C"
    else
        echo "N/A"
    fi
}

get_link_speed() {
    local sd="$1"

    # SAS: read negotiated_linkrate from the sysfs phy of the disk's port
    local dev_path port_dir phy_link phy_name rate
    dev_path=$(readlink -f "/sys/block/$sd/device" 2>/dev/null)
    if [[ -n "$dev_path" ]]; then
        port_dir=$(grep -oE '.*/port-[0-9:]+' <<< "$dev_path")
        if [[ -n "$port_dir" ]]; then
            phy_link=$(ls -d "$port_dir"/phy-* 2>/dev/null | head -1)
            if [[ -n "$phy_link" ]]; then
                phy_name=$(basename "$phy_link")
                rate=$(cat "/sys/class/sas_phy/$phy_name/negotiated_linkrate" 2>/dev/null)
                if [[ -n "$rate" && "$rate" != "unknown" ]]; then
                    echo "$rate"
                    return
                fi
            fi
        fi
    fi

    # SATA: parse from smartctl output
    _ensure_smart_cache "$sd"
    local output="${SMART_CACHE[$sd]}"
    if [[ -n "$output" ]]; then
        local sata_speed
        sata_speed=$(grep -i 'SATA Version' <<< "$output" | grep -oE 'current: [0-9.]+ Gb/s' | awk '{print $2 " " $3}')
        if [[ -n "$sata_speed" ]]; then
            echo "$sata_speed"
            return
        fi
    fi

    echo "N/A"
}

get_transport_type() {
    local sd="$1"
    local dev_path
    dev_path=$(readlink -f "/sys/block/$sd/device" 2>/dev/null) || { echo "N/A"; return; }
    if [[ "$dev_path" == */ata* ]]; then
        echo "SATA"
    elif [[ "$dev_path" == */expander-* || "$dev_path" == */port-* ]]; then
        echo "SAS"
    else
        echo "N/A"
    fi
}

get_health() {
    local sd="$1"
    _ensure_smart_cache "$sd"
    local output="${SMART_CACHE[$sd]}"
    [[ -z "$output" ]] && { echo "N/A"; return; }

    # SATA SSD: attribute 231 (SSD_Life_Left) — raw value is % directly
    local ssd_life
    ssd_life=$(awk '/^231 / {print $10}' <<< "$output" | head -1)
    if [[ -n "$ssd_life" && "$ssd_life" =~ ^[0-9]+$ ]]; then
        echo "${ssd_life}%"
        return
    fi

    # SATA HDD: attribute 5 (Reallocated_Sector_Ct) — normalized VALUE
    local realloc_val
    realloc_val=$(awk '/^  5 / {print $4}' <<< "$output" | head -1)
    if [[ -n "$realloc_val" && "$realloc_val" =~ ^[0-9]+$ ]]; then
        [[ "$realloc_val" -gt 100 ]] && realloc_val=100
        echo "${realloc_val}%"
        return
    fi

    # SAS: Elements in grown defect list
    local defects
    defects=$(grep -i 'Elements in grown defect list' <<< "$output" | awk '{print $NF}')
    if [[ -n "$defects" && "$defects" =~ ^[0-9]+$ ]]; then
        if [[ "$defects" -eq 0 ]]; then
            echo "100%"
        else
            echo "${defects}d"
        fi
        return
    fi

    echo "N/A"
}

print_disk() {
    local wwn="$1"
    local sd="${WWN_TO_SD[$wwn]}"

    local line
    line=$(grep -wF "/dev/$sd" <<< "$LSSCSI_OUTPUT" | head -1) || return 1
    [[ -z "$line" ]] && return 1

    local vendor model firmware
    vendor=$(awk '{print $3}'  <<< "$line")
    model=$(awk  '{print $4}'  <<< "$line")
    firmware=$(awk '{print $5}' <<< "$line")

    local aliases="${WWN_ALIASES[$wwn]:-none}"

    # Fix ATA devices: lsscsi reports "ATA" as vendor and the real
    # model string (which contains spaces) gets split across awk fields.
    # Extract real vendor/model from the ata-* identifier instead.
    if [[ "$vendor" == "ATA" ]]; then
        local ata_alias
        ata_alias=$(grep -oE 'ata-[^ ]+' <<< "$aliases")
        if [[ -n "$ata_alias" ]]; then
            local ata_info="${ata_alias#ata-}"
            # Remove serial number (last underscore-separated component)
            local ata_model="${ata_info%_*}"
            # Vendor is the first component
            vendor="${ata_model%%_*}"
            # Model is everything after the vendor
            model="${ata_model#*_}"
            model="${model//_/ }"
        fi
        # Firmware: lsscsi field position is shifted due to multi-word
        # product string; read the SCSI revision from sysfs instead.
        local rev_file="/sys/block/$sd/device/rev"
        if [[ -f "$rev_file" ]]; then
            firmware=$(<"$rev_file")
            firmware="${firmware#"${firmware%%[![:space:]]*}"}"
            firmware="${firmware%"${firmware##*[![:space:]]}"}"
        fi
    fi

    local in_pool="NO"
    is_in_pool "$wwn" && in_pool="YES"

    local enc_slot="" smart_status="" temp="" link_speed="" health=""
    if [[ "$VERBOSE" -eq 1 ]]; then
        enc_slot=$(get_enclosure_slot "$sd")
        smart_status=$(get_smart_status "$sd")
        temp=$(get_temperature "$sd")
        link_speed=$(get_link_speed "$sd")
        health=$(get_health "$sd")
    fi

    if [[ "$VERBOSE" -eq 1 ]]; then
        printf "%-8s %-50s %-10s %-20s %-8s %-8s %-20s %-7s %-5s %-14s %-8s\n" \
               "$sd" "$aliases" "$vendor" "$model" "$firmware" "$in_pool" \
               "$enc_slot" "$smart_status" "$temp" "$link_speed" "$health"
    else
        printf "%-8s %-50s %-10s %-20s %-8s %-8s\n" \
               "$sd" "$aliases" "$vendor" "$model" "$firmware" "$in_pool"
    fi
}

###############################################################################
# Main
###############################################################################

if [[ -z "$disk" ]]; then
    echo "=== All Disks in the Datacenter ==="
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf "%-8s %-50s %-10s %-20s %-8s %-8s %-20s %-7s %-5s %-14s %-8s\n" \
               "Device" "Identifiers" "Vendor" "Model" "FW" "Pool" \
               "Enclosure" "SMART" "Temp" "Link Speed" "Health"
        printf "%-8s %-50s %-10s %-20s %-8s %-8s %-20s %-7s %-5s %-14s %-8s\n" \
               "--------" "--------------------------------------------------" \
               "----------" "--------------------" "--------" "--------" \
               "--------------------" "-------" "-----" "--------------" "--------"
    else
        printf "%-8s %-50s %-10s %-20s %-8s %-8s\n" \
               "Device" "Identifiers" "Vendor" "Model" "FW" "Pool"
        printf "%-8s %-50s %-10s %-20s %-8s %-8s\n" \
               "--------" "--------------------------------------------------" \
               "----------" "--------------------" "--------" "--------"
    fi

    found=0
    count_sas=0
    count_sata=0
    count_other=0
    for wwn in "${ALL_WWNS[@]}"; do
        print_disk "$wwn" || continue
        found=$((found + 1))

        case $(get_transport_type "${WWN_TO_SD[$wwn]}") in
            SAS)  count_sas=$((count_sas + 1)) ;;
            SATA) count_sata=$((count_sata + 1)) ;;
            *)    count_other=$((count_other + 1)) ;;
        esac
    done

    echo ""
    summary="Total disks found: $found"
    details=()
    [[ $count_sas   -gt 0 ]] && details+=("${count_sas} SAS")
    [[ $count_sata  -gt 0 ]] && details+=("${count_sata} SATA")
    [[ $count_other -gt 0 ]] && details+=("${count_other} other")
    if [[ ${#details[@]} -gt 0 ]]; then
        IFS=', '; summary+=" (${details[*]})"; unset IFS
    fi
    echo "$summary"

else
    wwn=$(resolve_to_wwn "$disk") || {
        echo "Error: cannot resolve '$disk'"
        echo "Supported formats: scsi-..., wwn-..., ata-..., /dev/sdX, sdX"
        exit 1
    }
    sd="${WWN_TO_SD[$wwn]}"
    [[ -b "/dev/$sd" ]] || {
        echo "Error: /dev/$sd is not a block device"
        exit 1
    }
    if [[ "$VERBOSE" -eq 1 ]]; then
        printf "%-8s %-50s %-10s %-20s %-8s %-8s %-20s %-7s %-5s %-14s %-8s\n" \
               "Device" "Identifiers" "Vendor" "Model" "FW" "Pool" \
               "Enclosure" "SMART" "Temp" "Link Speed" "Health"
        printf "%-8s %-50s %-10s %-20s %-8s %-8s %-20s %-7s %-5s %-14s %-8s\n" \
               "--------" "--------------------------------------------------" \
               "----------" "--------------------" "--------" "--------" \
               "--------------------" "-------" "-----" "--------------" "--------"
    else
        printf "%-8s %-50s %-10s %-20s %-8s %-8s\n" \
               "Device" "Identifiers" "Vendor" "Model" "FW" "Pool"
        printf "%-8s %-50s %-10s %-20s %-8s %-8s\n" \
               "--------" "--------------------------------------------------" \
               "----------" "--------------------" "--------" "--------"
    fi
    print_disk "$wwn" || {
        echo "Error: /dev/$sd not found in lsscsi output"
        exit 1
    }
fi
