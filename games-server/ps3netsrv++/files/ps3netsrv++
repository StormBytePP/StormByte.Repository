depend() {
	need net localmount
}

start() {
	ebegin "Starting ${SVCNAME}"
	start-stop-daemon --start --exec /usr/bin/ps3netsrv++ \
		--make-pidfile --user "${PS3NETSRV_USER}" --group "${PS3NETSRV_GROUP}" --pidfile /var/run/ps3netsrv++.pid -b \
		-- "${PS3NETSRV_DIR}"
	eend $?
}

stop() {
	ebegin "Stopping ${SVCNAME}"
	start-stop-daemon --stop --exec /usr/bin/ps3netsrv++ \
		--pidfile /var/run/ps3netsrv++.pid
	eend $?
}
